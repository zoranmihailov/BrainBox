<Window x:Class="BrainBox.Views.CombinationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Комбинација" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        KeyDown="Window_KeyDown">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- Levo: legenda + prethodni obidi -->
        <StackPanel Grid.Column="0">
            <!-- Legenda -->
            <TextBlock Foreground="#888888" FontSize="14" Margin="0,0,0,5"
                       Text="1-★   2-♥   3-♠   4-♦   5-♣   6-●"/>
            <TextBlock Foreground="#888888" FontSize="14" Margin="0,0,0,15"
                       Text="Enter-Потврди   Backspace-Избриши последен   Delete-Избриши сè"/>

            <!-- Prethodni obidi -->
            <StackPanel x:Name="attemptsPanel" VerticalAlignment="Top"/>
        </StackPanel>

        <!-- Desno: kontroli -->
        <StackPanel Grid.Column="1" Margin="20,0,0,0">
            <TextBlock Text="Комбинација" Foreground="White" FontSize="20"
                       FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock x:Name="txtTimer" Foreground="#FF5555" FontSize="24"
                       FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock x:Name="txtAttempts" Foreground="#888888" FontSize="14"
                       Margin="0,0,0,20"/>

            <!-- Simboli za izbor -->
            <TextBlock Text="Избери симбол:" Foreground="White" FontSize="14"
                       Margin="0,0,0,10"/>
            <WrapPanel x:Name="symbolPanel" Margin="0,0,0,20"/>

            <!-- Momentalna kombinacija -->
            <TextBlock Text="Твој обид:" Foreground="White" FontSize="14"
           Margin="0,0,0,10"/>
            <StackPanel x:Name="currentGuess" Orientation="Horizontal" 
            Margin="0,0,0,20" Width="210"/>

            <Button Content="Потврди (Enter)" Height="40" Background="#4CAF50"
                    Foreground="White" FontSize="14" Click="ConfirmGuess">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Избриши последен (Backspace)" Height="40" Background="#FF8C00"
                    Foreground="White" FontSize="12" Margin="0,10,0,0" Click="RemoveLast">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Избриши сè (Delete)" Height="40" Background="#FF5555"
                    Foreground="White" FontSize="14" Margin="0,10,0,0" Click="ClearGuess">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <TextBlock x:Name="txtScore" Foreground="#4CAF50" FontSize="16"
                       Margin="0,20,0,0" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>