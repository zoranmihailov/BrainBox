<Window x:Class="BrainBox.Views.QuizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Прашања" Height="500" Width="840"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">
    <Window.Resources>
        <Style x:Key="AnswerButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="txtQuestionNum" Foreground="#888888" FontSize="14"
                       HorizontalAlignment="Left"/>
            <TextBlock x:Name="txtCategory" Foreground="#888888" FontSize="14"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="txtTimer" Foreground="#FF5555" FontSize="20"
                       FontWeight="Bold" HorizontalAlignment="Right"/>
        </Grid>
        <TextBlock x:Name="txtQuestion" Grid.Row="1" Foreground="White" FontSize="20"
                   FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,30"/>
        <UniformGrid Grid.Row="2" Rows="2" Columns="2">
            <Button x:Name="btnA" Style="{StaticResource AnswerButton}"
                    Background="#2D2D44" Click="AnswerClick"/>
            <Button x:Name="btnB" Style="{StaticResource AnswerButton}"
                    Background="#2D2D44" Click="AnswerClick"/>
            <Button x:Name="btnC" Style="{StaticResource AnswerButton}"
                    Background="#2D2D44" Click="AnswerClick"/>
            <Button x:Name="btnD" Style="{StaticResource AnswerButton}"
                    Background="#2D2D44" Click="AnswerClick"/>
        </UniformGrid>
        <TextBlock x:Name="txtScore" Grid.Row="4" Foreground="#4CAF50" FontSize="16"
                   HorizontalAlignment="Center" Margin="0,20,0,0"/>
    </Grid>
</Window>